{
  // * Window:
  "window.commandCenter": false,
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "hidden",
  "window.title": "${activeEditorShort}",

  // * Workbench:
  "workbench.activityBar.location": "default",
  "workbench.colorCustomizations": {
    "scrollbar.shadow": "#00000000"
    // "tab.activeBorderTop": "#00000000"
  },
  "workbench.editor.editorActionsLocation": "default",
  "workbench.editor.showTabs": "multiple",
  "workbench.colorTheme": "JetBrains New Dark",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.layoutControl.enabled": false,
  "workbench.settings.editor": "json",
  "workbench.statusBar.visible": true,
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.indent": 19,

  // * Editor:
  "editor.bracketPairColorization.enabled": false,
  "editor.cursorSurroundingLines": 7,
  "editor.detectIndentation": true,
  "editor.foldingImportsByDefault": false,
  "editor.fontFamily": "'Jetbrains Mono', 'Monaspace Neon', 'Fira Code', monospace",
  "editor.fontLigatures": "'calt', 'liga', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09'",
  "editor.fontSize": 14,
  "editor.hideCursorInOverviewRuler": true,
  "editor.insertSpaces": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "selection",
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": false,
  "editor.tabSize": 2,
  "editor.wordBasedSuggestions": "off",
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 120,
  // "editor.rulers": [120],
  // "editor.rulers": [72, 80, 100, 120],

  // * Terminal:
  "terminal.integrated.allowChords": false,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": ["-NoLogo"]
    }
  },
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.shellIntegration.enabled": false,

  // * Explorer:
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    ".env": ".env*",
    ".prettierrc": ".prettier*",
    "*": "${basename}.test.${extname}",
    "docker-compose*": ".dockerignore, Dockerfile*, dockerfile*",
    "pyproject.toml": ".python-version, alembic.ini, pdm.lock, Pipfile.lock, uv.lock",
    "package.json": ".prettier*, eslint*, package-lock.json, playwright*, pnpm-lock.yaml, tsconfig*, vite*, yarn.lock"
  },
  "explorer.sortOrderLexicographicOptions": "unicode",

  // * Files:
  "files.associations": {
    ".babelrc": "jsonc",
    ".eslintrc": "jsonc",
    ".prettierrc": "jsonc",
    "*.bats": "shellscript",
    "*.pyi": "python",
    "*.css": "css",
    "css": "css"
  },
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.coverage": true,
    "**/.DS_Store": true,
    "**/.idea": true,
    "**/.mypy_cache": true,
    "**/.netlify": true,
    "**/.pdm-python": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.turbo": true,
    "**/.venv": true,
    "**/.vs": true,
    "**/bin": true,
    "**/obj": true
  },

  // * Debug:
  "debug.allowBreakpointsEverywhere": true,
  "debug.console.closeOnEnd": true,
  "debug.console.collapseIdenticalLines": true,
  "debug.inlineValues": "on",

  // * Git:
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableCommitSigning": true,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",

  // * TODO:
  "todo-tree.filtering.useBuiltInExcludes": "file and search excludes",
  "todo-tree.general.showActivityBarBadge": true,
  "todo-tree.highlights.enabled": false,
  "todo-tree.tree.scanMode": "workspace only",
  "todo-tree.tree.showCurrentScanMode": false,
  "todo-tree.tree.tagsOnly": true,

  // * Python:
  "[python]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "ruff.enable": true,
  "ruff.nativeServer": "on",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportUnknownVariableType": "none",
    "reportUnknownMemberType": "none",
    "reportMissingTypeStubs": "none"
  },
  "python.analysis.typeCheckingMode": "strict",
  "python.terminal.activateEnvironment": false,

  // * Web:
  "[javascript][javascriptreact][typescript][typescriptreact][html][css][json][jsonc][markdown][mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[nginx]": {
    "editor.defaultFormatter": "ahmadalli.vscode-nginx-conf"
  },

  // * Catppuccin:
  "catppuccin-icons.associations.files": {
    "app.config.ts": "solid"
  },
  "catppuccin-icons.associations.extensions": {
    "tsx": "solid",
    "jsx": "solid",    
  },

  // * Security:
  "security.workspace.trust.enabled": false,

  // * Telemetry:
  "telemetry.telemetryLevel": "off",

  // * Remote:
  "remote.autoForwardPortsSource": "hybrid"
}
